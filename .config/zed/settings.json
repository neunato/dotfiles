{
   "theme": "Catppuccin Macchiato",
   "base_keymap": "None",
   "buffer_font_family": "JetBrains Mono",
   "buffer_font_size": 14,
   "buffer_font_weight": 400,
   "ui_font_family": "JetBrains Mono",
   "ui_font_size": 17,
   "ui_font_weight": 500,
   "agent_ui_font_size": 15,
   "agent_buffer_font_size": 13,
   "unnecessary_code_fade": 0.5,
   "image_viewer": {
      "unit": "decimal"
   },
   "multi_cursor_modifier": "cmd_or_ctrl",
   "hover_popover_delay": 225,
   "hover_popover_hiding_delay": 0,
   "restore_on_startup": "last_workspace",
   "cli_default_open_behavior": "new_window",
   "close_panel_on_toggle": true,
   "when_closing_with_no_tabs": "keep_window_open",
   "text_rendering_mode": "subpixel",
   "window_decorations": "server",
   "cursor_blink": false,
   "hide_mouse": "never",
   "lsp_highlight_debounce": 50,
   "minimum_contrast_for_highlights": 50,
   "show_signature_help_after_edits": true,
   "drag_and_drop_selection": {
      "enabled": false
   },
   "go_to_definition_scroll_strategy": "top",
   "redact_private_values": true,
   "expand_excerpt_lines": 15,
   "excerpt_context_lines": 3,
   "use_on_type_format": false,
   "always_treat_brackets_as_autoclosed": true,
   "show_edit_predictions": true,
   "edit_predictions_disabled_in": ["comment"],
   "toolbar": {
      "quick_actions": false
   },
   "title_bar": {
      "show_branch_name": false,
      "show_onboarding_banner": false,
      "show_user_picture": false,
      "show_user_menu": false,
      "show_sign_in": false
   },
   "scrollbar": {
      "selected_text": false,
      "selected_symbol": false,
      "diagnostics": "none"
   },
   "minimap": {
      "show": "always",
      "display_in": "all_editors",
      "thumb_border": "none",
      "max_width_columns": 90
   },
   "middle_click_paste": false,
   "gutter": {
      "runnables": false
   },
   "scroll_beyond_last_line": "off",
   "vertical_scroll_margin": 10,
   "horizontal_scroll_margin": 10,
   "scroll_sensitivity": 1.5,
   "mouse_wheel_zoom": true,
   "fast_scroll_sensitivity": 30.0,
   "search": {
      "button": false,
      "center_on_match": true
   },
   "resize_all_panels_in_dock": ["left", "bottom"],
   "project_panel": {
      "default_width": 300,
      "dock": "left",
      "entry_spacing": "standard",
      "indent_size": 21,
      "auto_reveal_entries": false,
      "auto_fold_dirs": false,
      "hide_root": true
   },
   "outline_panel": {
      "default_width": 300,
      "dock": "right",
      "indent_size": 18,
      "indent_guides": {
         "show": "never"
      }
   },
   "collaboration_panel": {
      "button": false
   },
   "git_panel": {
      "button": false
   },
   "message_editor": {
      "auto_replace_emoji_shortcode": false
   },
   "agent": {
      "dock": "right",
      "sidebar_side": "right",
      "default_width": 300,
      "limit_content_width": false,
      "default_model": {
         "provider": "anthropic",
         "model": "claude-sonnet-4-6-latest",
         "enable_thinking": true
      },
      "enable_feedback": false,
      "play_sound_when_agent_done": "always",
      "thinking_display": "always_collapsed",
      "show_turn_stats": true,
      "show_merge_conflict_indicator": false
   },
   "document_folding_ranges": "on",
   "tab_bar": {
      "show_nav_history_buttons": false,
      "show_tab_bar_buttons": false
   },
   "tabs": {
      "git_status": true
   },
   "preview_tabs": {
      "enable_preview_from_project_panel": true,
      "enable_preview_from_file_finder": false,
      "enable_preview_from_multibuffer": true,
      "enable_preview_multibuffer_from_code_navigation": true,
      "enable_preview_file_from_code_navigation": true,
      "enable_keep_preview_on_code_navigation": true
   },
   "extend_comment_on_newline": false,
   "line_ending": "enforce_lf",
   "format_on_save": "off",
   "preferred_line_length": 100000,
   "tab_size": 3,
   "telemetry": {
      "diagnostics": false,
      "metrics": false
   },
   "auto_update": false,
   "git": {
      "inline_blame": {
         "enabled": false
      },
      "blame": {
         "show_avatar": false
      },
      "branch_picker": {
         "show_author_name": false
      },
      "hunk_style": "unstaged_hollow",
      "path_style": "file_path_first",
      "show_stage_restore_buttons": false
   },
   "load_direnv": "disabled",
   "edit_predictions": {
      "provider": "copilot",
      "allow_data_collection": "no"
   },
   "journal": {
      "path": "~/.local/share/zed",
      "hour_format": "hour24"
   },
   "terminal": {
      "button": false,
      "shell": {
         "program": "fish"
      },
      "scroll_multiplier": 1.5,
      "minimum_contrast": 50
   },
   "file_types": {
      "Dockerfile": ["Dockerfile.*"]
   },
   "auto_install_extensions": {
      "catppuccin": true,
      "csv": true,
      "deno": true,
      "dockerfile": true,
      "fish": true,
      "git-firefly": true,
      "html": true,
      "ini": true,
      "java": true,
      "kdl": true,
      "log": true,
      "lua": true,
      "make": true,
      "scss": true,
      "sql": true,
      "strace": true,
      "svelte": true,
      "toml": true,
      "vue": true,
      "xml": true
   },
   "completions": {
      "words_min_length": 2
   },
   "jupyter": {
      "enabled": false
   },
   "agent_servers": {
      "claude-acp": {
         "type": "registry"
      }
   },
   "debugger": {
      "button": false
   }
}
